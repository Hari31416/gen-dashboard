# =============================================================================
# AI Dashboard - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# OS / System Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
nohup.out

# -----------------------------------------------------------------------------
# Docker Volumes (local data)
# -----------------------------------------------------------------------------
volumes/

# -----------------------------------------------------------------------------
# Python (Backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints/

# UV (Python package manager)
.uv/

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
dist/
.cache/
.parcel-cache/

# Vite
*.local

# TypeScript
*.tsbuildinfo

# ESLint / Prettier
.eslintcache

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
*._temp.*