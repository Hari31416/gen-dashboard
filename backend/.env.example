## ===== MONGODB =====
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_URI=

## ===== MARIADB =====
MARIADB_USER=root
MARIADB_PASSWORD=password
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_URI=

## ===== APPLICATION SETTINGS =====
DEFAULT_USERNAME=citizen
BACKEND_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8016
WORKERS=1
RELOAD=false
LOG_LEVEL=warning

## ===== LLM & MODEL CONFIGURATION =====
NVIDIA_NIM_API_KEY=
LLM_MODEL=nvidia_nim/openai/gpt-oss-120b
QUERY_SUGGESTION_GENERATION_MODEL=
REPORT_GENERATION_MODEL=
TITLE_GENERATION_MODEL=
NUM_RETRIES=0

## ===== LLM API KEYS =====
HUGGINGFACE_API_KEY=
HF_API_TOKEN=
GEMINI_API_KEY=

## ===== BHASHINI TRANSLATION =====
BHASHINI_ENDPOINT_URL=
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_LANG_DETECTION_SERVICE_ID=
BHASHINI_TRANSLATION_SERVICE_ID=

## ===== DATA & VISUALIZATION =====
USE_RAG_FOR_DATA_SELECTION=false
MATPLOTLIB_COLOR_MODE=light
PLOTLY_COLOR_MODE=light
MAX_ROWS_FETCH_DB_TABLE=1000000
DB_PASSWORD_ENCRYPTION_KEY=
USE_SAFE_EXECUTOR=true

## ===== ARTIFACT STORAGE (S3/MinIO) =====
ARTIFACT_STORAGE_ENABLED=false
S3_ENDPOINT_URL=http://localhost:9000/
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

## ===== PDF CONVERSION =====
USE_PANDOC_FOR_PDF_CONVERSION=false

## ===== ADMIN CREDENTIALS =====
ADMIN_USER_NAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=System Administrator

## ===== STARTUP CONFIGURATION =====
SKIP_STARTUP_CHECKS=false
SKIP_ADMIN_SETUP=false
RAISE_IF_MONGODB_NOT_ALIVE=true
RAISE_IF_MILVUS_NOT_ALIVE=true